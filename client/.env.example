# =============================================================================
# Avaya — Women Safety Web App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Required — Backend API
# -----------------------------------------------------------------------------
# Base URL for the Avaya Express backend API.
# Default: http://localhost:3000
#VITE_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional — Auth (Clerk) — Add when integrating authentication
# -----------------------------------------------------------------------------
# Get this from https://dashboard.clerk.com after creating an app.
# Leave empty or omit until you add auth.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
